{
  "manifest_version": 3,
  "name": "Family Guardian — Bộ lọc web",
  "version": "1.0.0",
  "description": "Kiểm soát truy cập web theo tài khoản Google",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "identity",
    "identity.email",
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png",
    "default_title": "Family Guardian"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "oauth2": {
    "client_id": "546760398169-09872hbivb30pa85m2h9rk5ibjgkpl62.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  }
}
